# Ignore generated macOS metadata when stowing dotfiles.
--ignore='\.DS_Store'
--ignore='\.CFUserTextEncoding'
--ignore='\._.*'
--ignore='\.AppleDouble'
--ignore='\.LSOverride'
--ignore='\.Spotlight-V100'
--ignore='\.TemporaryItems'
--ignore='\.Trashes'
--ignore='\.Trash'
--ignore='\.fseventsd'
--ignore='\.DocumentRevisions-V100'
--ignore='\.VolumeIcon\.icns'
--ignore='\.localized'
--ignore='\.metadata_never_index'
--ignore='\.apdisk'
--ignore='Icon\r'
--ignore='__MACOSX'
